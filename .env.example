# Copy this file to .env.local and fill in your own key. Never commit real keys.

# Your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional: override the model. Defaults to gpt-4o-mini (fast + cheap; the
# dataset is tiny so token cost is negligible).
OPENAI_MODEL=gpt-4o-mini
